# =============================================================================
# IDS/NIDS Pipeline - Git Ignore File
# =============================================================================

# =============================================================================
# Environment and Secrets
# =============================================================================
.env
.env.local
.env.*.local
*.env

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/
.ENV/

# =============================================================================
# Logs
# =============================================================================
*.log
logs/

# =============================================================================
# CSV Data Directories (sensitive data)
# =============================================================================
input_csv/
processed_csv/
results/

# =============================================================================
# Model Files (can be large)
# =============================================================================
isolation_model/*.pkl

# =============================================================================
# IDE and Editor Files
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# =============================================================================
# OS Generated Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# Testing
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/

.idea/